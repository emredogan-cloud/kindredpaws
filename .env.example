# Copy to `.env` (gitignored). Local, NON-SECRET dev defaults only.
# Real secrets belong in GitHub Actions Secrets and the backend secret manager —
# never in the client and never committed (this is a PUBLIC repo).

APP_ENV=dev

# ── LLM (Phase 1+, SERVER-SIDE ONLY; never ship a key in the app) ───────────
# ANTHROPIC_API_KEY=
# LLM_PREGEN_MODEL=claude-opus-4-8

# ── Firebase Test Lab / gcloud (device testing) ─────────────────────────────
# GOOGLE_CLOUD_PROJECT=
# FIREBASE_TOKEN=

# ── Codemagic (iOS CD) ──────────────────────────────────────────────────────
# CODEMAGIC_API_TOKEN=
